          <ui:InvokeCode ContinueOnError="{x:Null}" Code="If in_dtTriggersInput IsNot Nothing Then&#xA;    For Each row As DataRow In in_dtTriggersInput.Rows&#xA;        ' Read new column names from simplified Excel (Korean)&#xA;        Dim companyName As String = If(row.Table.Columns.Contains(&quot;회사명&quot;), row(&quot;회사명&quot;).ToString().Trim(), &quot;&quot;)&#xA;        If String.IsNullOrWhiteSpace(companyName) Then Continue For&#xA;        Dim tName As String = companyName &amp; &quot;_특정&quot;&#xA;        Dim pName As String = companyName &amp; &quot;_보유계약&quot;&#xA;        Dim domStr As String = If(row.Table.Columns.Contains(&quot;지정 날짜&quot;), row(&quot;지정 날짜&quot;).ToString().Trim(), &quot;&quot;)&#xA;        Dim startTimeStr As String = If(row.Table.Columns.Contains(&quot;실행 시작 시간&quot;), row(&quot;실행 시작 시간&quot;).ToString().Trim(), &quot;&quot;)&#xA;&#xA;        Try&#xA;            Dim orchestratorUrl As String = String.Format(&quot;https://cloud.uipath.com/{0}/{1}/orchestrator_&quot;, in_OrganizationName, in_TenantName)&#xA;            &#xA;            ' a. Verify Process Exists&#xA;            Dim releaseId As Long = 0&#xA;            If Not String.IsNullOrEmpty(in_AccessToken) Then&#xA;                Using releaseClient As New System.Net.Http.HttpClient()&#xA;                    releaseClient.DefaultRequestHeaders.Authorization = New System.Net.Http.Headers.AuthenticationHeaderValue(&quot;Bearer&quot;, in_AccessToken)&#xA;                    If Not String.IsNullOrEmpty(in_FolderId) Then&#xA;                        releaseClient.DefaultRequestHeaders.Add(&quot;X-UIPATH-OrganizationUnitId&quot;, in_FolderId)&#xA;                    End If&#xA;                    Dim releaseUrl As String = String.Format(&quot;{0}/odata/Releases?$filter=ProcessKey eq '{1}' or Name eq '{1}'&quot;, orchestratorUrl, pName)&#xA;                    Dim relResponse As System.Net.Http.HttpResponseMessage = releaseClient.GetAsync(releaseUrl).Result&#xA;                    If relResponse.IsSuccessStatusCode Then&#xA;                        Dim relJson As String = relResponse.Content.ReadAsStringAsync().Result&#xA;                        Dim regexId As New System.Text.RegularExpressions.Regex(&quot;&quot;&quot;Id&quot;&quot;\s*:\s*(\d+)&quot;)&#xA;                        Dim match As System.Text.RegularExpressions.Match = regexId.Match(relJson)&#xA;                        If match.Success Then&#xA;                            Long.TryParse(match.Groups(1).Value, releaseId)&#xA;                        End If&#xA;                    End If&#xA;                End Using&#xA;            End If&#xA;&#xA;            If releaseId = 0 Then Throw New Exception(&quot;Process '&quot; &amp; pName &amp; &quot;' not found.&quot;)&#xA;&#xA;            ' b. Check if Trigger already exists by Name&#xA;            Dim existingId As Long = 0&#xA;            If Not String.IsNullOrEmpty(in_AccessToken) Then&#xA;                Using checkClient As New System.Net.Http.HttpClient()&#xA;                    checkClient.DefaultRequestHeaders.Authorization = New System.Net.Http.Headers.AuthenticationHeaderValue(&quot;Bearer&quot;, in_AccessToken)&#xA;                    If Not String.IsNullOrEmpty(in_FolderId) Then&#xA;                        checkClient.DefaultRequestHeaders.Add(&quot;X-UIPATH-OrganizationUnitId&quot;, in_FolderId)&#xA;                    End If&#xA;                    ' Filter by Name to get existing Trigger ID&#xA;                    Dim checkUrl As String = String.Format(&quot;{0}/odata/ProcessSchedules?$filter=Name eq '{1}'&amp;$select=Id&quot;, orchestratorUrl, tName)&#xA;                    Dim checkResponse As System.Net.Http.HttpResponseMessage = checkClient.GetAsync(checkUrl).Result&#xA;                    If checkResponse.IsSuccessStatusCode Then&#xA;                        Dim checkJson As String = checkResponse.Content.ReadAsStringAsync().Result&#xA;                        Dim regexCheck As New System.Text.RegularExpressions.Regex(&quot;&quot;&quot;Id&quot;&quot;\s*:\s*(\d+)&quot;)&#xA;                        Dim matchCheck As System.Text.RegularExpressions.Match = regexCheck.Match(checkJson)&#xA;                        If matchCheck.Success Then&#xA;                            Long.TryParse(matchCheck.Groups(1).Value, existingId)&#xA;                        End If&#xA;                    End If&#xA;                End Using&#xA;            End If&#xA;&#xA;            ' c. Parse Time&#xA;            Dim parsedTime As DateTime&#xA;            Dim hours, minutes As Integer&#xA;            If DateTime.TryParse(startTimeStr, parsedTime) Then&#xA;                hours = parsedTime.Hour&#xA;                minutes = parsedTime.Minute&#xA;            Else&#xA;                Dim parts As String() = startTimeStr.Split(&quot;:&quot;c)&#xA;                hours = CInt(parts(0))&#xA;                minutes = CInt(parts(1))&#xA;            End If&#xA;&#xA;            ' d. Cron&#xA;            Dim domParts As String() = domStr.Split(New Char() {&quot;,&quot;c, &quot; &quot;c}, StringSplitOptions.RemoveEmptyEntries)&#xA;            Dim cleanedDom As String = String.Join(&quot;,&quot;, domParts)&#xA;            If String.IsNullOrWhiteSpace(cleanedDom) Then cleanedDom = &quot;*&quot;&#xA;            Dim cron As String = String.Format(&quot;0 {0} {1} {2} * ?&quot;, minutes, hours, cleanedDom)&#xA;&#xA;            ' e. API Call (Upsert)&#xA;            If Not String.IsNullOrEmpty(in_AccessToken) Then&#xA;                Using client As New System.Net.Http.HttpClient()&#xA;                    client.DefaultRequestHeaders.Authorization = New System.Net.Http.Headers.AuthenticationHeaderValue(&quot;Bearer&quot;, in_AccessToken)&#xA;                    If Not String.IsNullOrEmpty(in_FolderId) Then&#xA;                        client.DefaultRequestHeaders.Add(&quot;X-UIPATH-OrganizationUnitId&quot;, in_FolderId)&#xA;                    End If&#xA;                    &#xA;                    Dim q As String = Chr(34)&#xA;                    ' Advanced metadata is fine&#xA;                    Dim details As String = &quot;{}&quot;&#xA;                    &#xA;                    ' Payload base&#xA;                    Dim payloadBase As String = q &amp; &quot;Name&quot; &amp; q &amp; &quot;:&quot; &amp; q &amp; tName &amp; q &amp; &quot;,&quot; &amp; q &amp; &quot;ReleaseId&quot; &amp; q &amp; &quot;:&quot; &amp; releaseId &amp; &quot;,&quot; &amp; q &amp; &quot;StartStrategy&quot; &amp; q &amp; &quot;:1,&quot; &amp; q &amp; &quot;StartProcessCron&quot; &amp; q &amp; &quot;:&quot; &amp; q &amp; cron &amp; q &amp; &quot;,&quot; &amp; q &amp; &quot;StartProcessCronDetails&quot; &amp; q &amp; &quot;:&quot; &amp; q &amp; details &amp; q &amp; &quot;,&quot; &amp; q &amp; &quot;TimeZoneId&quot; &amp; q &amp; &quot;:&quot; &amp; q &amp; &quot;Korea Standard Time&quot; &amp; q &amp; &quot;,&quot; &amp; q &amp; &quot;Enabled&quot; &amp; q &amp; &quot;:true&quot;&#xA;                    &#xA;                    Dim response As System.Net.Http.HttpResponseMessage&#xA;                    If existingId &gt; 0 Then&#xA;                        ' PUT to update&#xA;                        Dim triggerId As Long = existingId&#xA;                        Dim putUrl As String = String.Format(&quot;{0}/odata/ProcessSchedules({1})&quot;, orchestratorUrl, triggerId)&#xA;                        ' Adding ID to payload for PUT&#xA;                        Dim putPayload As String = &quot;{&quot; &amp; q &amp; &quot;Id&quot; &amp; q &amp; &quot;:&quot; &amp; triggerId &amp; &quot;,&quot; &amp; payloadBase &amp; &quot;}&quot;&#xA;                        Dim putContent As New System.Net.Http.StringContent(putPayload, System.Text.Encoding.UTF8)&#xA;                        putContent.Headers.ContentType = New System.Net.Http.Headers.MediaTypeHeaderValue(&quot;application/json&quot;)&#xA;                        response = client.PutAsync(putUrl, putContent).Result&#xA;                    Else&#xA;                        ' POST to create&#xA;                        Dim postUrl As String = orchestratorUrl &amp; &quot;/odata/ProcessSchedules&quot;&#xA;                        Dim postPayload As String = &quot;{&quot; &amp; payloadBase &amp; &quot;}&quot;&#xA;                        Dim postContent As New System.Net.Http.StringContent(postPayload, System.Text.Encoding.UTF8)&#xA;                        postContent.Headers.ContentType = New System.Net.Http.Headers.MediaTypeHeaderValue(&quot;application/json&quot;)&#xA;                        response = client.PostAsync(postUrl, postContent).Result&#xA;                    End If&#xA;&#xA;                    If Not response.IsSuccessStatusCode Then&#xA;                        Throw New Exception(&quot;API Error: &quot; &amp; response.Content.ReadAsStringAsync().Result)&#xA;                    End If&#xA;                End Using&#xA;            End If&#xA;&#xA;            io_dtReport.Rows.Add(tName, &quot;Success&quot;, &quot;Cron: &quot; &amp; cron)&#xA;        Catch ex As Exception&#xA;            io_dtReport.Rows.Add(tName, &quot;Failed&quot;, ex.Message)&#xA;        End Try&#xA;    Next&#xA;End If" DisplayName="Invoke Code: Process Rows" sap:VirtualizedContainerService.HintSize="488,197" sap2010:WorkflowViewState.IdRef="InvokeCode_3">
