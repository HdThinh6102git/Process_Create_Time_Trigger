          <ui:InvokeCode ContinueOnError="{x:Null}" Code="Dim sb As New System.Text.StringBuilder()&#xA;sb.AppendLine(&quot;Trigger Name,Status,Message&quot;)&#xA;&#xA;Dim hasError As Boolean = False&#xA;For Each row As DataRow In in_dtReport.Rows&#xA;    Dim triggerName As String = row(&quot;TriggerName&quot;).ToString().Replace(&quot;&quot;&quot;&quot;, &quot;&quot;&quot;&quot;&quot;&quot;)&#xA;    Dim status As String = row(&quot;Status&quot;).ToString().Replace(&quot;&quot;&quot;&quot;, &quot;&quot;&quot;&quot;&quot;&quot;)&#xA;    Dim message As String = row(&quot;Message&quot;).ToString().Replace(&quot;&quot;&quot;&quot;, &quot;&quot;&quot;&quot;&quot;&quot;)&#xA;    &#xA;    If status.Equals(&quot;Failed&quot;, StringComparison.OrdinalIgnoreCase) Then&#xA;        hasError = True&#xA;    End If&#xA;&#xA;    sb.AppendLine(String.Format(&quot;&quot;&quot;{0}&quot;&quot;,&quot;&quot;{1}&quot;&quot;,&quot;&quot;{2}&quot;&quot;&quot;, triggerName, status, message))&#xA;Next&#xA;&#xA;System.IO.File.WriteAllText(in_OutputPath, sb.ToString(), System.Text.Encoding.UTF8)&#xA;&#xA;If hasError Then&#xA;    Throw New Exception(&quot;There were failed rows.&quot;)&#xA;End If" DisplayName="Invoke Code: Write CSV" sap:VirtualizedContainerService.HintSize="488,188" sap2010:WorkflowViewState.IdRef="InvokeCode_4">
